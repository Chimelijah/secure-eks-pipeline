# Security: Ensure sensitive files are never committed
*.tfstate diff=exif
*.tfstate.backup diff=exif
.env diff=exif
.env.local diff=exif

# Line endings
* text=auto
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.tf text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
